# Merchant Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Port (optional, defaults to 4000)
PORT=4000

# Stripe Configuration (Merchant's Stripe account)
# Get your secret key from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE

# ============================================================================
# SPT (Shared Payment Token) Modes
# ============================================================================
#
# SIMULATION MODE (Agent has SPT_SIMULATION_MODE=true):
#   - Merchant receives tokens like: spt_sim_cus_xxx_pm_xxx_timestamp
#   - Merchant extracts payment method ID and charges directly
#   - REQUIRES: Same Stripe account as Agent Service
#
# PRODUCTION MODE (Agent has SPT_SIMULATION_MODE not set):
#   - Merchant receives real SPT tokens: spt_xxx
#   - Merchant uses shared_payment_granted_token parameter
#   - ALLOWS: Different Stripe account from Agent Service
#
# The merchant backend automatically detects which mode based on token format.
# No configuration needed here - just ensure correct Stripe key is set.
